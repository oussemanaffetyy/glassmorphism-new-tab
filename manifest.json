{
  "manifest_version": 3,
  "name": "Aura — New Tab",
  "version": "1.0.0",
  "description": "A serene, glassy new tab dashboard with weather, search, quick links and daily focus.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage",
    "geolocation"
  ],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*"
  ],
  "icons": {
    "16": "icons/icon-128.png",
    "48": "icons/icon-128.png",
    "128": "icons/icon-128.png"
  }
}
